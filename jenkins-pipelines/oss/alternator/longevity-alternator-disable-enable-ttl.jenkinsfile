#!groovy

/** jobDescription
    Longevity test on 6-node cluster.
        Stress tool: ycsb.
        Runs for 50 minutes.
        Tests DynamoDB-compatible Alternator API.
        Part of the longevity suite.
        Labels: alternator, authentication, longevity
*/

// trick from https://github.com/jenkinsci/workflow-cps-global-lib-plugin/pull/43
def lib = library identifier: 'sct@snapshot', retriever: legacySCM(scm)

longevityPipeline(
    backend: 'aws',
    region: 'eu-west-1',
    test_name: 'longevity_alternator_ttl_test.AlternatorTtlLongevityTest.test_disable_enable_ttl_scan',
    test_config: 'test-cases/features/alternator-ttl/longevity-alternator-disable-enable-ttl.yaml',

    email_recipients: 'qa@scylladb.com'
)
